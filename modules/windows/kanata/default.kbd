;; CapsLock is remapped to LeftCtrl by the OS-level Scancode Map,
;; so kanata sees lctl here. Tap = Esc, Hold = Ctrl.

(defcfg
  process-unmapped-keys yes
)

(defsrc
  lctl
)

(defvar
  tap-time  200
  hold-time 200
)

(defalias
  lctl (tap-hold-press $tap-time $hold-time esc lctl)
)

(deflayer base
  @lctl
)
